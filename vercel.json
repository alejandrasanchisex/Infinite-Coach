{
  "version": 2,
  "framework": "nextjs",
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/client-login", "destination": "/acceso", "permanent": false },
    { "source": "/client-login.html", "destination": "/acceso", "permanent": false },
    { "source": "/client-dashboard", "destination": "/dashboard", "permanent": false },
    { "source": "/client-dashboard.html", "destination": "/dashboard", "permanent": false },
    { "source": "/client-diet", "destination": "/diet", "permanent": false },
    { "source": "/client-diet.html", "destination": "/diet", "permanent": false },
    { "source": "/client-routine", "destination": "/routine", "permanent": false },
    { "source": "/client-routine.html", "destination": "/routine", "permanent": false },
    { "source": "/client-habits", "destination": "/habits", "permanent": false },
    { "source": "/client-habits.html", "destination": "/habits", "permanent": false },
    { "source": "/client-evolution", "destination": "/evolution", "permanent": false },
    { "source": "/client-evolution.html", "destination": "/evolution", "permanent": false },
    { "source": "/client-feedback", "destination": "/feedback", "permanent": false },
    { "source": "/client-feedback.html", "destination": "/feedback", "permanent": false },
    { "source": "/client-profile", "destination": "/profile", "permanent": false },
    { "source": "/client-profile.html", "destination": "/profile", "permanent": false },
    { "source": "/client-library", "destination": "/library", "permanent": false },
    { "source": "/client-library.html", "destination": "/library", "permanent": false }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/version.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/trainer-(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/client-(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/admin-(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ]
}
